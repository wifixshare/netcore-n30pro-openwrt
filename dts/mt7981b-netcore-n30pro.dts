/*
 * Netcore N30PRO Device Tree
 * Based on bfdeh/openwrt official support
 * Hardware: MT7981B + MT7531AE + MT7976CN + 128MB NAND + 512MB RAM
 * Ports: 1x WAN + 4x LAN + 1x USB3.0
 */

/dts-v1/;
#include "mt7981b-netis-common.dtsi"

/ {
	model = "Netcore N30PRO";
	compatible = "netcore,n30pro", "cmcc,rax3000m", "mediatek,mt7981";

	aliases {
		label-mac-device = &gmac0;
		led-boot = &led_wps;
		led-failsafe = &led_wps;
		led-running = &led_wps;
		led-upgrade = &led_wps;
	};

	leds {
		compatible = "gpio-leds";

		internet {
			color = <LED_COLOR_ID_GREEN>;
			function = LED_FUNCTION_WAN_ONLINE;
			gpios = <&pio 9 GPIO_ACTIVE_LOW>;
		};

		led_wps: wps {
			color = <LED_COLOR_ID_GREEN>;
			function = LED_FUNCTION_WPS;
			gpios = <&pio 5 GPIO_ACTIVE_LOW>;
		};

		wifi2g {
			color = <LED_COLOR_ID_GREEN>;
			function = LED_FUNCTION_WLAN_2GHZ;
			gpios = <&pio 34 GPIO_ACTIVE_LOW>;
			linux,default-trigger = "phy0tpt";
		};

		wifi5g {
			color = <LED_COLOR_ID_GREEN>;
			function = LED_FUNCTION_WLAN_5GHZ;
			gpios = <&pio 35 GPIO_ACTIVE_LOW>;
			linux,default-trigger = "phy1tpt";
		};

		wan {
			color = <LED_COLOR_ID_GREEN>;
			function = LED_FUNCTION_WAN;
			gpios = <&pio 8 GPIO_ACTIVE_LOW>;
		};

		usb {
			color = <LED_COLOR_ID_GREEN>;
			function = LED_FUNCTION_USB;
			gpios = <&pio 13 GPIO_ACTIVE_LOW>;
		};
	};

	reg_5v: regulator-5v {
		compatible = "regulator-fixed";
		regulator-name = "fixed-5V";
		regulator-min-microvolt = <5000000>;
		regulator-max-microvolt = <5000000>;
		gpio = <&pio 23 GPIO_ACTIVE_HIGH>;
		enable-active-high;
	};
};

&switch {
	ports {
		port@0 { reg = <0>; label = "lan1"; };
		port@1 { reg = <1>; label = "lan2"; };
		port@2 { reg = <2>; label = "lan3"; };
		port@3 { reg = <3>; label = "lan4"; };
	};
};

&usb_phy { status = "okay"; };

&xhci {
	vbus-supply = <&reg_5v>;
	status = "okay";
};
